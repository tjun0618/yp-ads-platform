.layout{display:flex;gap:20px;align-items:flex-start;}
</style>
</head>
<body>
"""
    + _SCRAPE_TOPNAV
    + """
<div class="page">
  <div class="layout">
    <div class="cat-sidebar">
      <div class="cat-list" id="catList">
        <div class="cat-item active" data-cat="ALL" onclick="selectCatByEl(this)">全部类别</div>
